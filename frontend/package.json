{
    "version": "2.0.1",
    "name": "@navikt/endringslogg",
    "author": "NAV",
    "type": "module",
    "homepage": "https://github.com/navikt/endringslogg#readme",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/navikt/endringslogg"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "module": "dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "yarn run clean && yarn run copy-css && yarn run tsc",
        "clean": "rm -rf ./dist",
        "copy-css": "copyfiles -u 1 \"src/**/*.css\" dist",
        "lint": "eslint src",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "tsc": "tsc -p tsconfig.json"
    },
    "dependencies": {
        "@portabletext/react": "6.2.0",
        "classnames": "2.5.1"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@navikt/aksel-icons": "8.10.6",
        "@navikt/ds-css": "8.10.6",
        "@navikt/ds-react": "8.10.6",
        "@storybook/addon-essentials": "8.6.14",
        "@storybook/react-vite": "10.3.6",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "copyfiles": "2.4.1",
        "eslint": "10.3.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react-hooks": "7.1.1",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "storybook": "10.3.6",
        "typescript": "6.0.3",
        "typescript-eslint": "8.59.3",
        "vite": "8.0.12"
    },
    "peerDependencies": {
        "@navikt/aksel-icons": "8.x",
        "@navikt/ds-react": "8.x",
        "@types/react": "18.x || 19.x",
        "react": "18.x || 19.x"
    },
    "packageManager": "yarn@4.12.0"
}
